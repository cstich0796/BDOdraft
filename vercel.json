{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/jb.js", "use": "@vercel/node" },
    { "src": "api/mlb.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/jb", "dest": "/api/jb.js" },
    { "src": "/api/mlb", "dest": "/api/mlb.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
